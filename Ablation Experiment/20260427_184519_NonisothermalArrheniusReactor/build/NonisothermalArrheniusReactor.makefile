# Makefile generated by OpenModelica
# Platform: win64

# Simulations use -O3 by default
CC=clang
CXX=clang++
LINK=clang++ -shared -Xlinker --export-all-symbols
EXEEXT=.exe
DLLEXT=.dll
CFLAGS_BASED_ON_INIT_FILE=
# define OMC_CFLAGS_OPTIMIZATION env variable to your desired optimization level to override this
OMC_CFLAGS_OPTIMIZATION=-Os
DEBUG_FLAGS=$(OMC_CFLAGS_OPTIMIZATION)
CFLAGS=-municode $(CFLAGS_BASED_ON_INIT_FILE) $(DEBUG_FLAGS) -DOM_HAVE_PTHREADS -Wno-parentheses-equality -falign-functions -mstackrealign -msse2 -mfpmath=sse ${MODELICAUSERCFLAGS}   
CPPFLAGS= -I"D:/software/OpenModelica1.25.5-64bit/include/omc/c" -I"D:/software/OpenModelica1.25.5-64bit/include/omc" -I. -DOPENMODELICA_XML_FROM_FILE_AT_RUNTIME -DOMC_MODEL_PREFIX=NonisothermalArrheniusReactor -DOMC_NUM_MIXED_SYSTEMS=0 -DOMC_NUM_LINEAR_SYSTEMS=0 -DOMC_NUM_NONLINEAR_SYSTEMS=0 -DOMC_NDELAY_EXPRESSIONS=0 -DOMC_NVAR_STRING=0
# define OMC_LDFLAGS_LINK_TYPE env variable to "static" to override this
OMC_LDFLAGS_LINK_TYPE=dynamic
RUNTIME_LIBS=-lSimulationRuntimeC -Wl,-Bdynamic -lomcgc -lryu -lopenblas -Wl,-B$(OMC_LDFLAGS_LINK_TYPE)  -lstdc++ -Wl,-Bdynamic 
LDFLAGS=-L"D:/software/OpenModelica1.25.5-64bit/lib//omc" -L"D:/software/OpenModelica1.25.5-64bit/lib" -Wl,--stack,16777216,-rpath,"D:/software/OpenModelica1.25.5-64bit/lib//omc" -L"D:/software/OpenModelica1.25.5-64bit/bin" -Wl,-rpath,"D:/software/OpenModelica1.25.5-64bit/lib"  -fopenmp -Wl,-Bstatic -lregex -ltre -lintl -liconv -lexpat -lpthread -loleaut32 -limagehlp -lhdf5 -lz -lsz -Wl,-Bdynamic $(RUNTIME_LIBS) 
DIREXTRA=-L"C:/Users/FST/Desktop/实验组4/cases/20260427_184519_NonisothermalArrheniusReactor/build/src"
MAINFILE=NonisothermalArrheniusReactor.c
MAINOBJ=NonisothermalArrheniusReactor.o
CFILES=NonisothermalArrheniusReactor_functions.c NonisothermalArrheniusReactor_records.c \
NonisothermalArrheniusReactor_01exo.c NonisothermalArrheniusReactor_02nls.c NonisothermalArrheniusReactor_03lsy.c NonisothermalArrheniusReactor_04set.c NonisothermalArrheniusReactor_05evt.c NonisothermalArrheniusReactor_06inz.c NonisothermalArrheniusReactor_07dly.c \
NonisothermalArrheniusReactor_08bnd.c NonisothermalArrheniusReactor_09alg.c NonisothermalArrheniusReactor_10asr.c NonisothermalArrheniusReactor_11mix.c NonisothermalArrheniusReactor_12jac.c NonisothermalArrheniusReactor_13opt.c NonisothermalArrheniusReactor_14lnz.c \
NonisothermalArrheniusReactor_15syn.c NonisothermalArrheniusReactor_16dae.c NonisothermalArrheniusReactor_17inl.c NonisothermalArrheniusReactor_18spd.c 

OFILES=$(CFILES:.c=.o)
GENERATEDFILES=$(MAINFILE) NonisothermalArrheniusReactor.makefile NonisothermalArrheniusReactor_literals.h NonisothermalArrheniusReactor_functions.h $(CFILES)

.PHONY: omc_main_target clean bundle

# This is to make sure that NonisothermalArrheniusReactor_*.c are always compiled.
.PHONY: $(CFILES)

omc_main_target: $(MAINOBJ) NonisothermalArrheniusReactor_functions.h NonisothermalArrheniusReactor_literals.h $(OFILES)
	$(CC) -I. -o NonisothermalArrheniusReactor$(EXEEXT) $(MAINOBJ) $(OFILES) $(DIREXTRA)   $(CFLAGS) $(CPPFLAGS) $(LDFLAGS)

omc_dll_target: $(MAINOBJ) NonisothermalArrheniusReactor_functions.h NonisothermalArrheniusReactor_literals.h $(OFILES)
	$(CC) -DOMC_DLL_MAIN_DEFINE -o $(MAINOBJ) -c $(MAINFILE) $(DIREXTRA)   $(CFLAGS) $(CPPFLAGS) $(LDFLAGS)
	$(CC) -shared -I. -o NonisothermalArrheniusReactor$(DLLEXT) $(MAINOBJ) $(OFILES) $(DIREXTRA)   $(CFLAGS) $(CPPFLAGS) $(LDFLAGS)

clean:
	@rm -f NonisothermalArrheniusReactor_records.o $(MAINOBJ)

bundle:
	@tar -cvf NonisothermalArrheniusReactor_Files.tar $(GENERATEDFILES)