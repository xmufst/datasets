# Makefile generated by OpenModelica
# Platform: win64

# Simulations use -O3 by default
CC=clang
CXX=clang++
LINK=clang++ -shared -Xlinker --export-all-symbols
EXEEXT=.exe
DLLEXT=.dll
CFLAGS_BASED_ON_INIT_FILE=
# define OMC_CFLAGS_OPTIMIZATION env variable to your desired optimization level to override this
OMC_CFLAGS_OPTIMIZATION=-Os
DEBUG_FLAGS=$(OMC_CFLAGS_OPTIMIZATION)
CFLAGS=-municode $(CFLAGS_BASED_ON_INIT_FILE) $(DEBUG_FLAGS) -DOM_HAVE_PTHREADS -Wno-parentheses-equality -falign-functions -mstackrealign -msse2 -mfpmath=sse ${MODELICAUSERCFLAGS}   
CPPFLAGS= -I"D:/software/OpenModelica1.25.5-64bit/include/omc/c" -I"D:/software/OpenModelica1.25.5-64bit/include/omc" -I. -DOPENMODELICA_XML_FROM_FILE_AT_RUNTIME -DOMC_MODEL_PREFIX=PiecewiseAdiabaticStirredTank -DOMC_NUM_MIXED_SYSTEMS=0 -DOMC_NUM_LINEAR_SYSTEMS=0 -DOMC_NUM_NONLINEAR_SYSTEMS=0 -DOMC_NDELAY_EXPRESSIONS=0 -DOMC_NVAR_STRING=0
# define OMC_LDFLAGS_LINK_TYPE env variable to "static" to override this
OMC_LDFLAGS_LINK_TYPE=dynamic
RUNTIME_LIBS=-lSimulationRuntimeC -Wl,-Bdynamic -lomcgc -lryu -lopenblas -Wl,-B$(OMC_LDFLAGS_LINK_TYPE)  -lstdc++ -Wl,-Bdynamic 
LDFLAGS=-L"D:/software/OpenModelica1.25.5-64bit/lib//omc" -L"D:/software/OpenModelica1.25.5-64bit/lib" -Wl,--stack,16777216,-rpath,"D:/software/OpenModelica1.25.5-64bit/lib//omc" -L"D:/software/OpenModelica1.25.5-64bit/bin" -Wl,-rpath,"D:/software/OpenModelica1.25.5-64bit/lib"  -fopenmp -Wl,-Bstatic -lregex -ltre -lintl -liconv -lexpat -lpthread -loleaut32 -limagehlp -lhdf5 -lz -lsz -Wl,-Bdynamic $(RUNTIME_LIBS) 
DIREXTRA=-L"C:/Users/FST/Desktop/实验组2/cases/20260427_205711_PiecewiseAdiabaticStirredTank/build/src"
MAINFILE=PiecewiseAdiabaticStirredTank.c
MAINOBJ=PiecewiseAdiabaticStirredTank.o
CFILES=PiecewiseAdiabaticStirredTank_functions.c PiecewiseAdiabaticStirredTank_records.c \
PiecewiseAdiabaticStirredTank_01exo.c PiecewiseAdiabaticStirredTank_02nls.c PiecewiseAdiabaticStirredTank_03lsy.c PiecewiseAdiabaticStirredTank_04set.c PiecewiseAdiabaticStirredTank_05evt.c PiecewiseAdiabaticStirredTank_06inz.c PiecewiseAdiabaticStirredTank_07dly.c \
PiecewiseAdiabaticStirredTank_08bnd.c PiecewiseAdiabaticStirredTank_09alg.c PiecewiseAdiabaticStirredTank_10asr.c PiecewiseAdiabaticStirredTank_11mix.c PiecewiseAdiabaticStirredTank_12jac.c PiecewiseAdiabaticStirredTank_13opt.c PiecewiseAdiabaticStirredTank_14lnz.c \
PiecewiseAdiabaticStirredTank_15syn.c PiecewiseAdiabaticStirredTank_16dae.c PiecewiseAdiabaticStirredTank_17inl.c PiecewiseAdiabaticStirredTank_18spd.c 

OFILES=$(CFILES:.c=.o)
GENERATEDFILES=$(MAINFILE) PiecewiseAdiabaticStirredTank.makefile PiecewiseAdiabaticStirredTank_literals.h PiecewiseAdiabaticStirredTank_functions.h $(CFILES)

.PHONY: omc_main_target clean bundle

# This is to make sure that PiecewiseAdiabaticStirredTank_*.c are always compiled.
.PHONY: $(CFILES)

omc_main_target: $(MAINOBJ) PiecewiseAdiabaticStirredTank_functions.h PiecewiseAdiabaticStirredTank_literals.h $(OFILES)
	$(CC) -I. -o PiecewiseAdiabaticStirredTank$(EXEEXT) $(MAINOBJ) $(OFILES) $(DIREXTRA)   $(CFLAGS) $(CPPFLAGS) $(LDFLAGS)

omc_dll_target: $(MAINOBJ) PiecewiseAdiabaticStirredTank_functions.h PiecewiseAdiabaticStirredTank_literals.h $(OFILES)
	$(CC) -DOMC_DLL_MAIN_DEFINE -o $(MAINOBJ) -c $(MAINFILE) $(DIREXTRA)   $(CFLAGS) $(CPPFLAGS) $(LDFLAGS)
	$(CC) -shared -I. -o PiecewiseAdiabaticStirredTank$(DLLEXT) $(MAINOBJ) $(OFILES) $(DIREXTRA)   $(CFLAGS) $(CPPFLAGS) $(LDFLAGS)

clean:
	@rm -f PiecewiseAdiabaticStirredTank_records.o $(MAINOBJ)

bundle:
	@tar -cvf PiecewiseAdiabaticStirredTank_Files.tar $(GENERATEDFILES)